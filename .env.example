# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Primary (via PgBouncer)
POSTGRES_DB=RNS
POSTGRES_USER=notif_user
POSTGRES_PASSWORD=notif_pass_123
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# PostgreSQL Replica (via PgBouncer)
POSTGRES_REPLICA_DB=RNS_replica
POSTGRES_REPLICA_HOST=pgbouncer
POSTGRES_REPLICA_PORT=6432

# PostgreSQL Replication
REPLICATION_PASSWORD=repl_pass_123

# Redis (3 separate instances in Docker)
REDIS_CHANNELS_URL=redis://redis-channels:6379/0
REDIS_CELERY_URL=redis://redis-celery:6379/0
REDIS_CACHE_URL=redis://redis-cache:6379/0

# RabbitMQ Cluster
RABBITMQ_URL=amqp://guest:guest@rabbitmq-1:5672/
RABBITMQ_MANAGEMENT_PORT=15672

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=notifications@example.com

# Firebase (Push)
FCM_SERVER_KEY=your-fcm-server-key-here
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-credentials.json

# Celery
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq-1:5672/
CELERY_RESULT_BACKEND=redis://redis-celery:6379/0

# RabbitMQ Cluster Cookie
RABBITMQ_ERLANG_COOKIE=rns_cluster_cookie_secret

# OpenTelemetry / Jaeger (Distributed Tracing)
OTEL_ENABLED=True
OTEL_JAEGER_HOST=jaeger
OTEL_JAEGER_PORT=6831
OTEL_SERVICE_NAME=rns-notification-system

# Notification System Tuning (optional — defaults shown)
# CIRCUIT_BREAKER_FAIL_MAX=5
# CIRCUIT_BREAKER_RESET_TIMEOUT=60
# IDEMPOTENCY_TTL=86400
# DLQ_MAX_ATTEMPTS=10
# DLQ_BATCH_SIZE=100
# DIGEST_MAX_NOTIFICATIONS=50
# CLEANUP_READ_AFTER_DAYS=90
# CLEANUP_FCM_AFTER_DAYS=30
# BULK_BATCH_SIZE=1000
# DEFAULT_NOTIFICATION_PRIORITY=5
