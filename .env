# Django
SECRET_KEY=django-insecure-dev-key-change-in-production-abc123xyz
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL Primary (via PgBouncer)
POSTGRES_DB=RNS
POSTGRES_USER=postgres
POSTGRES_PASSWORD=raj123
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# PostgreSQL Replica (via PgBouncer) — pointing to primary since replica has startup issue
POSTGRES_REPLICA_DB=RNS
POSTGRES_REPLICA_HOST=pgbouncer
POSTGRES_REPLICA_PORT=6432

# PostgreSQL Replication
REPLICATION_PASSWORD=repl_pass_123

# Redis
REDIS_CHANNELS_URL=redis://redis-channels:6379/0
REDIS_CELERY_URL=redis://redis-celery:6379/0
REDIS_CACHE_URL=redis://redis-cache:6379/0

# RabbitMQ Cluster
RABBITMQ_URL=amqp://guest:guest@rabbitmq-1:5672/
RABBITMQ_MANAGEMENT_PORT=15672

# SendGrid (Email)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=notifications@example.com

# Firebase (Push)
FCM_SERVER_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-credentials.json

# Celery (broker points to RabbitMQ cluster node 1)
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq-1:5672/
CELERY_RESULT_BACKEND=redis://redis-celery:6379/0

# RabbitMQ Cluster Cookie (must match across all nodes)
RABBITMQ_ERLANG_COOKIE=rns_cluster_cookie_secret

# OpenTelemetry / Jaeger (Distributed Tracing)
OTEL_ENABLED=True
OTEL_JAEGER_HOST=jaeger
OTEL_JAEGER_PORT=6831
OTEL_SERVICE_NAME=rns-notification-system
